{
  "mcpServers": {
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "env": {}
    },
    "agentation": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "agentation-mcp",
        "server"
      ],
      "env": {}
    },
    "figma-desktop": {
      "type": "http",
      "url": "http://127.0.0.1:3845/mcp"
    },
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp"
    },
    "debugmcp": {
      "type": "http",
      "url": "http://localhost:3001/mcp"
    }
  }
}
